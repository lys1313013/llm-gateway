# PostgreSQL
# DB 独立部署（docker-compose.db.yml），宿主机端口由 DB_PORT 控制。
# DB_HOST：
#   - 宿主机直连：localhost
#   - 容器内访问：host.docker.internal（macOS/Windows），或宿主机 IP（Linux）
DB_HOST=localhost
DB_PORT=35432
DB_NAME=llm_gateway
DB_USER=postgres
DB_PASSWORD=password
DB_TIMEZONE=Asia/Shanghai

# 后端
# 宿主机端口（容器内仍为 5001）
BACKEND_HOST_PORT=33352

# 前端
# 宿主机端口（容器内仍为 80）
FRONTEND_HOST_PORT=33380

# ===== Auth =====
# JWT signing secret — CHANGE THIS in production!
JWT_SECRET_KEY=change-me-to-a-random-secret-string

# token有效期
JWT_EXPIRATION_HOURS=168

# ===== Session tracking =====
# Comma-separated list of request header names scanned (in order) for a
# session id, stored in api_logs.session_id. The first non-empty value wins.
# Default recognizes Claude Code's X-Claude-Code-Session-Id. Add other
# agent headers (e.g. X-Agent-Session-Id) to support multiple clients.
# SESSION_ID_HEADERS=X-Claude-Code-Session-Id,X-Agent-Session-Id
